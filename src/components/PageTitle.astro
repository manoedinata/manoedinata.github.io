---
const { title, description } = Astro.props;
---

<!-- Page Title -->
<div class="page-title" data-aos="fade">
  <div class="heading">
    <div class="container">
      <div class="row d-flex justify-content-center text-center">
        <div class="col-lg-8">
          <h1>{title}</h1>
          <p class="mb-0">
            {description}
          </p>
        </div>
      </div>
    </div>
  </div>
</div>
<!-- End Page Title -->
